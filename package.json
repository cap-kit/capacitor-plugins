{
  "name": "capacitor-plugins",
  "author": "CapKit Team",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "turbo run build",
    "clean": "pnpm -r run clean",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "lint:all": "turbo run lint",
    "build:all": "turbo run build",
    "test:all": "turbo run test",
    "lint:packages": "pnpm -r lint",
    "build:packages": "pnpm -r build",
    "test:packages": "pnpm -r test",
    "verify": "pnpm -r run verify",
    "format": "pnpm -r run format",
    "docgen": "pnpm -r run docgen",
    "readme:reset": "tsx scripts/reset-readme.ts",
    "readme:update": "tsx scripts/update-readme.ts",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && pnpm changeset publish"
  },
  "lint-staged": {
    "packages/**/package.json": [
      "pnpm run readme:update",
      "git add README.md"
    ],
    "**/*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "**/*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.1"
  }
}
